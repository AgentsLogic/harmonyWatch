{
  "name": "harmonywatchv1",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "node scripts/generate-version.mjs && next build",
    "start": "next start",
    "deploy": "npm run build && git add . && git commit -m \"Deploy: $(date)\" && git push origin main",
    "build:capacitor": "node scripts/export-to-capacitor.mjs",
    "cap:sync": "npx cap sync",
    "cap:sync:ios": "npx cap sync ios",
    "cap:sync:android": "npx cap sync android",
    "cap:open": "npx cap open ios",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npx cap run android",
    "android:sync": "node scripts/sync-android.mjs",
    "package:volt:capacitor": "node scripts/package-volt-capacitor.mjs",
    "package:android": "node scripts/package-android-release.mjs",
    "dev:ios": "cross-env CAPACITOR_DEV=true npm run build:capacitor && npm run cap:open:ios",
    "dev:ios:sync": "cross-env CAPACITOR_DEV=true npm run build:capacitor",
    "dev:android": "cross-env CAPACITOR_DEV=true npm run build:capacitor && npm run cap:open:android",
    "dev:android:sync": "cross-env CAPACITOR_DEV=true npm run build:capacitor",
    "dev:android:run": "cross-env CAPACITOR_DEV=true npm run build:capacitor && npm run cap:run:android",
    "dev:sync": "cross-env CAPACITOR_DEV=true npm run build:capacitor",
    "build:android:debug": "powershell -ExecutionPolicy Bypass -File scripts/build-android-debug.ps1",
    "android:clean": "powershell -ExecutionPolicy Bypass -File android/clean-all-builds.ps1",
    "android:clean:sync": "npm run android:clean && npm run build:capacitor",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/splash-screen": "^7.0.4",
    "@capacitor/status-bar": "^7.0.4",
    "@ionic/core": "^8.7.10",
    "@ionic/react": "^8.7.10",
    "@mediagrid/capacitor-native-audio": "^2.0.0",
    "@mux/mux-node": "^12.8.0",
    "@mux/mux-player-react": "^3.6.1",
    "@mux/mux-uploader": "^1.3.0",
    "@mux/mux-uploader-react": "^1.3.0",
    "@mux/mux-video-react": "^0.27.0",
    "@revenuecat/purchases-capacitor": "^11.2.13",
    "@revenuecat/purchases-js": "^1.18.2",
    "@supabase/supabase-js": "^2.75.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.2",
    "browser-image-compression": "^2.0.2",
    "envalid": "^8.1.0",
    "framer-motion": "^12.23.24",
    "hls.js": "^1.6.13",
    "ios-webkit-debug-proxy": "^0.0.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.5.7",
    "player.style": "^0.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-loading-indicators": "^1.0.1",
    "remotedebug-ios-webkit-adapter": "^0.1.6",
    "sharp": "^0.34.5",
    "stripe": "^19.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/ios": "^7.4.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/webpack": "^5.28.5",
    "archiver": "^7.0.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "yarn@4.5.3+sha512.3003a14012e2987072d244c720506549c1aab73ee728208f1b2580a9fd67b92d61ba6b08fe93f6dce68fd771e3af1e59a0afa28dd242dd0940d73b95fedd4e90"
}
