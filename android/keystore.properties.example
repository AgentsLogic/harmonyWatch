# Android Signing Configuration
# Copy this file to keystore.properties and fill in your actual values
# This file is gitignored - never commit the actual keystore.properties file

# Path to keystore file (relative to android/ directory)
storeFile=harmony-release-key.jks

# Keystore password
storePassword=your_keystore_password_here

# Key alias name
keyAlias=harmony-key

# Key password (can be same as storePassword)
keyPassword=your_key_password_here
